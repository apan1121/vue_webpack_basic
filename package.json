{
  "name": "vue3_webpack",
  "version": "1.0.0",
  "description": "Vue3 Webpack",
  "main": "",
  "scripts": {
    "build:dev": "cross-env NODE_ENV=development webpack --mode development --config ./webpack5/webpack.config.js --color --watch",
    "build:prod": "cross-env NODE_ENV=production webpack --mode production --config ./webpack5/webpack.config.js --color",
    "build:dll:dev": "cross-env NODE_ENV=development webpack --mode development --config ./webpack5/webpack.config.dll.js --color",
    "build:dll:prod": "cross-env NODE_ENV=production webpack --mode production --config ./webpack5/webpack.config.dll.js --color",
    "build:analyze": "cross-env NODE_ENV=production webpack --mode production --config-name js --config ./webpack5/webpack.config.js --color --analyze",
    "build:dll:analyze": "cross-env NODE_ENV=production webpack --mode production --config ./webpack5/webpack.config.dll.js --color --analyze",
    "clean:before": "rm -rf ./dist",
    "clean:after": "rm -rf ./dist/js/css_del",
    "dev": "npm run clean:before && npm run build:dll:dev && npm run build:dev",
    "build": "npm run clean:before && npm run build:dll:prod && npm run build:prod && npm run clean:after"
  },
  "keywords": [
    "Vue3",
    "Webpack5"
  ],
  "author": "byron chen",
  "license": "ISC",
